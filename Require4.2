import streamlit as st
import os
from moviepy.editor import VideoFileClip

VIDEO_FOLDER = "uploads/videos"
CLIP_FOLDER = "uploads/clips"

os.makedirs(CLIP_FOLDER, exist_ok=True)


def scene_selection():

    st.header("✂ Scene Selection")

    videos = [
        f for f in os.listdir(VIDEO_FOLDER)
        if f.lower().endswith(
            (".mp4", ".mov", ".avi", ".mkv", ".webm", ".mpeg")
        )
    ]

    if len(videos) == 0:
        st.warning("No uploaded videos found.")
        return

    selected_video = st.selectbox(
        "Select Video",
        videos
    )

    video_path = os.path.join(VIDEO_FOLDER, selected_video)

    st.video(video_path)

    clip = VideoFileClip(video_path)

    duration = clip.duration

    st.write(f"Duration : {round(duration,2)} seconds")

    start_time = st.slider(
        "Start Time",
        0.0,
        float(duration),
        0.0
    )

    end_time = st.slider(
        "End Time",
        0.0,
        float(duration),
        float(duration)
    )

    if start_time >= end_time:
        st.error("End Time must be greater than Start Time.")
        return

    st.write(
        f"Selected : {round(start_time,2)} sec → {round(end_time,2)} sec"
    )

    if st.button("✂ Trim & Save Clip"):

        new_clip = clip.subclip(start_time, end_time)

        filename = (
            os.path.splitext(selected_video)[0]
            + "_clip.mp4"
        )

        output_path = os.path.join(CLIP_FOLDER, filename)

        new_clip.write_videofile(
            output_path,
            codec="libx264",
            audio_codec="aac"
        )

        st.success("Clip Saved Successfully!")

        st.video(output_path)

        st.write("Saved Location:")

        st.code(output_path)

        new_clip.close()

    clip.close()
